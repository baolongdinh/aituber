# Server Settings
PORT=8080
TEMP_DIR=./temp
OUTPUT_DIR=../ai-videos
CACHE_DIR=./cache

# Subtitles
ENABLE_SUBTITLES=false

# Database (PostgreSQL)
DATABASE_HOST=CHANGE-ME
DATABASE_PORT=CHANGE-ME
DATABASE_USER=CHANGE-ME
DATABASE_PASSWORD=CHANGE-ME
DATABASE_NAME=CHANGE-ME

# JWT Authentication
JWT_SECRET=your-secret-key-here
JWT_ACCESS_TOKEN_EXPIRY_HOURS=24

# API Keys (comma-separated for pools)
TTS_API_KEYS=key1,key2
ELEVENLABS_API_KEY=your-elevenlabs-key
VIDEO_API_KEYS=key1,key2
GEMINI_API_KEYS=key1,key2
PEXELS_API_KEY=your-pexels-key
HF_TOKEN=hf_token1,hf_token2

# Hub Service Settings
LOCAL_HUB_URL=http://localhost:5000
REMOTE_HUB_URL=http://10.0.0.224:8081
REMOTE_HUB_TOKEN=your-remote-hub-token

# Processing Settings
MAX_TEXT_LENGTH=50000
AUDIO_CHUNK_SIZE=8000
VIDEO_SEGMENT_DURATION=10.0

# Quality Settings
AUDIO_SAMPLE_RATE=44100
AUDIO_BITRATE=320k
VIDEO_BITRATE=8M
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=30

# Transition Settings
AUDIO_CROSSFADE_DURATION=0.0
VIDEO_TRANSITION_TYPE=fade
VIDEO_TRANSITION_DURATION=0.5

# Rate Limiting & Concurrent Requests
MAX_CONCURRENT_TTS_REQUESTS=1
MAX_CONCURRENT_VIDEO_REQUESTS=5
RETRY_DELAY_SECONDS=60
